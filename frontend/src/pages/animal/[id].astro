---
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';

export function getStaticPaths() {
  const dataDir = join(process.cwd(), '../data/animals');
  const files = readdirSync(dataDir).filter(f => f.endsWith('.json') && !f.startsWith('_'));
  return files.map(f => {
    const animal = JSON.parse(readFileSync(join(dataDir, f), 'utf-8'));
    return { params: { id: animal.id }, props: { animal } };
  });
}

const { animal } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{animal.name} — Animal Facts</title>
    <style>
      body { font-family: sans-serif; max-width: 860px; margin: 2rem auto; padding: 0 1rem; }
      a { color: #2563eb; }
      h1 { font-size: 1.8rem; margin-bottom: 0.25rem; }
      .scientific { color: #666; font-style: italic; margin-bottom: 1.5rem; }
      .domain { margin: 2rem 0; }
      .domain h2 { font-size: 1.2rem; text-transform: capitalize; border-bottom: 2px solid #eee; padding-bottom: 0.25rem; }
      .use { margin: 1.5rem 0 1.5rem 1rem; }
      .use h3 { font-size: 1rem; margin-bottom: 0.5rem; }
      .meta-row { font-size: 0.85rem; color: #444; margin: 0.25rem 0; }
      .method { background: #f9f9f9; border-left: 3px solid #ccc; padding: 0.75rem 1rem; margin: 0.5rem 0; font-size: 0.9rem; }
      .method strong { display: block; margin-bottom: 0.25rem; }
      .legal { font-size: 0.8rem; color: #888; }
      .fact { border: 1px solid #eee; border-radius: 6px; padding: 0.75rem; margin: 0.5rem 0; font-size: 0.9rem; }
      .fact .value { font-weight: bold; }
      .source { font-size: 0.78rem; color: #888; margin-top: 0.25rem; }
      .unverified { color: #b45309; font-size: 0.75rem; }
      .back { margin-bottom: 1.5rem; display: block; }
    </style>
  </head>
  <body>
    <a class="back" href="/">← Todos los animales</a>
    <h1>{animal.name}</h1>
    <div class="scientific">{animal.scientificName}</div>

    {animal.lifeExpectancy?.wild?.range && (
      <p>Esperanza de vida en libertad (rango de la especie): <strong>{animal.lifeExpectancy.wild.range}</strong></p>
    )}

    {animal.domains.filter((d: any) => d.uses.length > 0).map((domain: any) => (
      <div class="domain">
        <h2>Ámbito: {domain.domain}</h2>
        {domain.uses.map((use: any) => (
          <div class="use">
            <h3>{use.use}</h3>

            {use.lifeExpectancy?.wild?.value && (
              <div class="meta-row">
                Esperanza de vida en libertad (esta raza): <strong>{use.lifeExpectancy.wild.value}</strong>
                {use.lifeExpectancy.wild.note && <span> — {use.lifeExpectancy.wild.note}</span>}
              </div>
            )}

            {use.slaughter?.typicalAgeAtKill?.value && (
              <div class="meta-row">
                Edad de sacrificio: <strong>{use.slaughter.typicalAgeAtKill.value}</strong>
                {use.slaughter.typicalAgeAtKill.context && <span> — {use.slaughter.typicalAgeAtKill.context}</span>}
              </div>
            )}

            {use.slaughter?.methods?.length > 0 && (
              <div>
                <strong style="font-size:0.85rem">Métodos de sacrificio:</strong>
                {use.slaughter.methods.map((m: any) => (
                  <div class="method">
                    <strong>{m.method}</strong>
                    {m.description && <p style="margin:0.25rem 0">{m.description}</p>}
                    <div class="legal">{m.legalBasis} — {m.scope}</div>
                    {m.source?.url && (
                      <div class="source">
                        Fuente: <a href={m.source.url} target="_blank" rel="noopener">{m.source.name}</a>
                        {!m.verified && <span class="unverified"> (pendiente de verificación)</span>}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}

            {use.facts?.length > 0 && (
              <div>
                {use.facts.map((fact: any) => (
                  <div class="fact">
                    <div>{fact.statement}</div>
                    <div class="value">{fact.value}</div>
                    {fact.source?.url && (
                      <div class="source">
                        <a href={fact.source.url} target="_blank" rel="noopener">{fact.source.name}</a>
                        {!fact.verified && <span class="unverified"> (pendiente de verificación)</span>}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}

            {use.media?.filter((m: any) => m.url).map((m: any) => (
              <div class="meta-row">
                Video: <a href={m.url} target="_blank" rel="noopener">{m.title}</a>
                {!m.verified && <span class="unverified"> (URL pendiente de verificación)</span>}
              </div>
            ))}
          </div>
        ))}
      </div>
    ))}
  </body>
</html>
